{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://frsca.dev/provenance/ml-feature-extraction/v0.1",
  "title": "FRSCA-ML Feature Extraction Predicate",
  "description": "in-toto predicate for Feature Extraction runs.",
  "type": "object",
  "properties": {
    "predicateType": {
      "type": "string",
      "const": "https://frsca.dev/provenance/ml-feature-extraction/v0.1"
    },
    "predicate": {
      "type": "object",
      "properties": {
        "runDetails": {
          "type": "object",
          "properties": {
            "builder": {
              "type": "object",
              "properties": {
                "id": { "type": "string" }
              },
              "required": ["id"]
            },
            "metadata": {
              "type": "object",
              "properties": {
                "startedOn": { "type": "string", "format": "date-time" },
                "finishedOn": { "type": "string", "format": "date-time" }
              }
            }
          },
          "required": ["builder"]
        },
        "featureSpecifics": {
          "type": "object",
          "properties": {
            "featureViewId": { "type": "string" },
            "featureDefinitions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "type": { "type": "string" }
                }
              }
            },
            "inputDatasets": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "uri": { "type": "string" },
                  "digest": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  }
                },
                "required": ["name", "uri", "digest"]
              }
            }
          },
          "required": ["featureViewId", "inputDatasets"]
        }
      },
      "required": ["runDetails", "featureSpecifics"]
    }
  },
  "required": ["predicateType", "predicate"]
}
