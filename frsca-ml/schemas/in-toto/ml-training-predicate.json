{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://frsca.dev/provenance/ml-training/v0.2",
  "title": "FRSCA-ML Training Predicate",
  "description": "in-toto predicate for Machine Learning training runs, extending SLSA build details with ML specifics.",
  "type": "object",
  "properties": {
    "predicateType": {
      "type": "string",
      "const": "https://frsca.dev/provenance/ml-training/v0.2"
    },
    "predicate": {
      "type": "object",
      "properties": {
        "buildDefinition": {
          "type": "object",
          "description": "Standard SLSA BuildDefinition.",
          "properties": {
            "buildType": { "type": "string" },
            "externalParameters": { "type": "object" },
            "systemParameters": { "type": "object" }
          },
          "required": ["buildType", "externalParameters"]
        },
        "runDetails": {
          "type": "object",
          "properties": {
            "builder": {
              "type": "object",
              "properties": {
                "id": { "type": "string" }
              },
              "required": ["id"]
            },
            "metadata": {
              "type": "object",
              "properties": {
                "startedOn": { "type": "string", "format": "date-time" },
                "finishedOn": { "type": "string", "format": "date-time" }
              }
            }
          },
          "required": ["builder"]
        },
        "mlSpecifics": {
          "type": "object",
          "properties": {
            "hyperparameters": {
              "type": "object",
              "description": "Key-value pairs of training hyperparameters."
            },
            "environment": {
              "type": "object",
              "properties": {
                "framework": { "type": "string" },
                "frameworkVersion": { "type": "string" },
                "accelerator": { "type": "string" },
                "driverVersion": { "type": "string" }
              }
            },
            "metrics": {
              "type": "object",
              "description": "Key-value pairs of final validation metrics.",
              "properties": {
                "accuracy": { "type": "number" },
                "loss": { "type": "number" },
                "f1_score": { "type": "number" }
              }
            },
            "datasets": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "uri": { "type": "string" },
                  "digest": {
                    "type": "object",
                    "additionalProperties": { "type": "string" }
                  }
                },
                "required": ["name", "uri", "digest"]
              }
            },
            "featureViews": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "uri": { "type": "string" }
                },
                "required": ["id"]
              }
            }
          },
          "required": ["hyperparameters", "environment", "metrics", "datasets"]
        }
      },
      "required": ["buildDefinition", "runDetails", "mlSpecifics"]
    }
  },
  "required": ["predicateType", "predicate"]
}
