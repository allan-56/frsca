{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://frsca.dev/provenance/ml-evaluation/v0.1",
  "title": "FRSCA-ML Model Evaluation Predicate",
  "description": "in-toto predicate for Model Evaluation runs.",
  "type": "object",
  "properties": {
    "predicateType": {
      "type": "string",
      "const": "https://frsca.dev/provenance/ml-evaluation/v0.1"
    },
    "predicate": {
      "type": "object",
      "properties": {
        "runDetails": {
          "type": "object",
          "properties": {
            "builder": {
              "type": "object",
              "properties": {
                "id": { "type": "string" }
              },
              "required": ["id"]
            },
            "metadata": {
              "type": "object",
              "properties": {
                "startedOn": { "type": "string", "format": "date-time" },
                "finishedOn": { "type": "string", "format": "date-time" }
              }
            }
          },
          "required": ["builder"]
        },
        "evaluationSpecifics": {
          "type": "object",
          "properties": {
            "modelId": { "type": "string" },
            "modelDigest": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "evaluationDataset": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "uri": { "type": "string" },
                "digest": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              },
              "required": ["uri", "digest"]
            },
            "metrics": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            },
            "thresholds": {
              "type": "object",
              "additionalProperties": { "type": "number" }
            },
            "passed": { "type": "boolean" }
          },
          "required": ["modelId", "modelDigest", "evaluationDataset", "metrics", "passed"]
        }
      },
      "required": ["runDetails", "evaluationSpecifics"]
    }
  },
  "required": ["predicateType", "predicate"]
}
